# --- Executables & Binaries ---
# Ignore files with no extension (standard Linux/C compiled binaries)
*
!*/
!*.*

# Specifically ignore common output names if you use them
a.out
*.o
*.out
*.app

# --- Build Directories ---
# If you eventually use Make or CMake
build/
bin/
obj/

# --- IDEs & Editors ---
# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# Neovim / Vim
*.swp
*.swo
Session.vim
.netrwhist

# --- OS Specific ---
.DS_Store
Thumbs.db